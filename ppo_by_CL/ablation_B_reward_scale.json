{
    "format_version": "ppo_runtime_phase1_v1",
    "phase": "1",
    "training_mode": "single_actor",
    "node_bin": "node",
    "env_bridge_script": "ppo/scripts/ppo_env_bridge.mjs",
    "rule_key": "A",
    "control_actor": "human",
    "first_turn_policy": "alternate",
    "fixed_first_turn": "human",
    "max_episode_steps": 700,
    "downside_penalty_scale": 0.0005,
    "terminal_bonus_scale": 0.003,
    "terminal_win_bonus": 1.0,
    "terminal_loss_penalty": 1.0,
    "go_action_bonus": 0.2,
    "env_workers": 6,
    "total_updates": 500,
    "rollout_steps": 512,
    "minibatch_size": 1024,
    "ppo_epochs": 4,
    "gamma": 0.995,
    "gae_lambda": 0.95,
    "clip_coef": 0.2,
    "learning_rate": 0.0003,
    "learning_rate_final": 0.00012,
    "entropy_coef": 0.01,
    "value_coef": 0.5,
    "value_clip_coef": 0.2,
    "target_kl": 0.02,
    "max_grad_norm": 0.5,
    "catastrophic_loss_threshold": -7000,
    "catastrophic_penalty_scale": 0.0002,
    "early_stop_patience_updates": 9999,
    "early_stop_min_updates": 9999,
    "gru_num_layers": 1,
    "gru_seq_len": 16,
    "hidden_size": 256,
    "device": "cpu",
    "log_every_updates": 20,
    "save_every_updates": 500,
    "seed": "abl_B",
    "reward_scale": 0.01,
    "go_explore_prob": 0.25,
    "opponent_policy": "H-J1:0.50|H-Gemini:0.20|H-AntiCL:0.20|H-J2:0.10",
    "opponent_policy_schedule": [
        {
            "start_update": 1,
            "opponent_policy": "H-J1:0.50|H-Gemini:0.20|H-AntiCL:0.20|H-J2:0.10"
        },
        {
            "start_update": 501,
            "opponent_policy": "H-J2:0.40|H-NEXg:0.30|H-AntiCL:0.20|H-GPT:0.10"
        },
        {
            "start_update": 1001,
            "opponent_policy": "H-CL:0.40|H-J2:0.30|H-NEXg:0.20|H-GPT:0.10"
        }
    ],
    "output_dir": "logs/PPO/ablation_B_reward_scale",
    "output_dir_template": "logs/PPO/ablation_B_reward_scale_{seed}",
    "_ablation_desc": "reward_scale 0.01 only"
}