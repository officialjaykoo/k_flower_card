{
  "format_version": "ppo_runtime_phase1_v1",
  "phase": "1",
  "seed": "90",
  "training_mode": "single_actor",
  "node_bin": "node",
  "env_bridge_script": "ppo/scripts/ppo_env_bridge.mjs",
  "rule_key": "A",
  "control_actor": "human",
  "opponent_policy": "H-CL:0.60|H-J2:0.15|H-AntiCL:0.15|H-NEXg:0.10",
  "first_turn_policy": "alternate",
  "fixed_first_turn": "human",
  "max_episode_steps": 700,
  "reward_scale": 0.001,
  "downside_penalty_scale": 0.0005,
  "terminal_bonus_scale": 0.003,
  "terminal_win_bonus": 1.0,
  "terminal_loss_penalty": 1.0,
  "env_workers": 6,
  "total_updates": 2000,
  "rollout_steps": 512,
  "minibatch_size": 1024,
  "ppo_epochs": 4,
  "gamma": 0.995,
  "gae_lambda": 0.95,
  "clip_coef": 0.2,
  "learning_rate": 0.0003,
  "learning_rate_final": 0.00005,
  "entropy_coef": 0.01,
  "value_coef": 0.5,
  "value_clip_coef": 0.2,
  "target_kl": 0.02,
  "max_grad_norm": 0.5,
  "catastrophic_loss_threshold": -12000,
  "catastrophic_penalty_scale": 0.0002,
  "best_gold_tolerance": 300.0,
  "early_stop_patience_updates": 250,
  "early_stop_min_updates": 800,
  "hidden_size": 256,
  "device": "cpu",
  "log_every_updates": 5,
  "save_every_updates": 25,
  "output_dir": "logs/PPO/vs_hcl_phase1_seed90",
  "output_dir_template": "logs/PPO/vs_hcl_phase1_seed{seed}",
  "resume_checkpoint": "logs/PPO/vs_hcl_phase1_seed90/latest.pt",
  "resume_checkpoint_template": "logs/PPO/vs_hcl_phase1_seed{seed}/latest.pt"
}
